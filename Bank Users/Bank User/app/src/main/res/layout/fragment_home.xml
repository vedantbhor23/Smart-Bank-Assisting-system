<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/background_light"
    tools:context="com.example.bankassist.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Select Video Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="5dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/teal_700">

            <Button
                android:id="@+id/btn_select_video"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Video"
                android:backgroundTint="@color/teal_700"
                android:textColor="@android:color/white"
                android:padding="12dp"
                android:textSize="16sp"/>
        </androidx.cardview.widget.CardView>

        <!-- Video Player Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="5dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@android:color/white">

            <com.google.android.exoplayer2.ui.PlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:visibility="gone"/>
        </androidx.cardview.widget.CardView>

        <!-- Upload & Transcribe Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="5dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@android:color/white">

            <Button
                android:id="@+id/btn_upload_video"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Upload and Transcribe"
                android:padding="12dp"
                android:textSize="16sp"
                android:visibility="gone"/>
        </androidx.cardview.widget.CardView>

        <!-- Transcription Output Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="5dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@android:color/white">

            <TextView
                android:id="@+id/tv_transcription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Transcription will appear here..."
                android:textSize="16sp"
                android:textColor="@android:color/black"/>
        </androidx.cardview.widget.CardView>

        <!-- Identify Intent Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="5dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@android:color/white">

            <Button
                android:id="@+id/btn_identify_intent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Identify Intent"
                android:padding="12dp"
                android:textSize="16sp"
                android:visibility="gone"/>
        </androidx.cardview.widget.CardView>

        <!-- Identified Intent Output -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_identified_intent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="5dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@android:color/white"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_identified_intent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Identified Intent will appear here..."
                android:textSize="16sp"
                android:textColor="@android:color/black"/>
        </androidx.cardview.widget.CardView>

        <!-- Save to Firebase Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="5dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@android:color/white">

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save to Firebase"
                android:padding="12dp"
                android:textSize="16sp"
                android:visibility="gone"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
